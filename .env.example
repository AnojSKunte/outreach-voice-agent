# ─────────────────────────────────────────────────────────────
# Outreach — Voice AI Calling Agent
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored and must NEVER be committed.
# In production, set these as environment variables in Render.
# ─────────────────────────────────────────────────────────────

# --- Speech-to-text (Deepgram) ---
DEEPGRAM_API_KEY=

# --- LLM (OpenAI) ---
OPENAI_API_KEY=
# Model used for in-call reasoning + tool calling. Override per agent if needed.
LLM_MODEL=gpt-4o-mini

# --- Text-to-speech (Cartesia) ---
CARTESIA_API_KEY=

# --- Telephony (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Server ---
# Public hostname Twilio uses to reach this server (no scheme), e.g.
# outreach-voice-agent.onrender.com   (set automatically-ish on Render)
PUBLIC_HOST=
# Port the web service listens on. Render injects PORT; default for local dev.
PORT=8000

# Optional: which agent answers a call to an unknown/unmapped number.
# Useful while testing on a Twilio trial number before the India DID is live.
DEFAULT_AGENT_ID=seaside-hotel
