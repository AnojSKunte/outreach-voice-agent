# ─────────────────────────────────────────────────────────────
# Outreach — AI Calling Agent
# Copy to `.env` and fill in what you have. `.env` is gitignored
# and must NEVER be committed. In production, set these as host
# environment variables (Render dashboard etc.).
#
# You do NOT need every key. Minimum viable sets:
#   premium profile: DEEPGRAM + OPENAI + CARTESIA (+ Twilio to take calls)
#   budget profile:  SARVAM + GROQ            (+ Twilio/Exotel)
# ─────────────────────────────────────────────────────────────

# ── PREMIUM profile providers ────────────────────────────────
# Deepgram STT — $200 free credit, no card: https://console.deepgram.com
DEEPGRAM_API_KEY=
# OpenAI LLM: https://platform.openai.com
OPENAI_API_KEY=
# Cartesia TTS — free tier: https://play.cartesia.ai
CARTESIA_API_KEY=
# Optional premium TTS alternative: https://elevenlabs.io
ELEVENLABS_API_KEY=

# ── BUDGET profile providers (India-first) ───────────────────
# Sarvam AI (Saarika STT + Bulbul TTS, best Hindi/Hinglish) —
# ₹1,000 free credit: https://dashboard.sarvam.ai
SARVAM_API_KEY=
# Groq LLM — generous free tier: https://console.groq.com
GROQ_API_KEY=
# Optional: Gemini Flash as budget LLM (needs pipecat-ai[google])
GOOGLE_API_KEY=

# Default provider profile for agents that don't pin one: premium | budget
DEFAULT_PROFILE=premium
LLM_MODEL=gpt-4o-mini
BUDGET_LLM_MODEL=llama-3.3-70b-versatile

# ── Telephony ────────────────────────────────────────────────
# twilio (dev + international) | exotel (India production)
TELEPHONY_PROVIDER=twilio

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The Twilio number outbound calls are placed FROM (E.164)
TWILIO_FROM_NUMBER=

# Exotel (only if TELEPHONY_PROVIDER=exotel)
EXOTEL_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_FROM_NUMBER=
EXOTEL_SUBDOMAIN=api.exotel.com

# ── Server ───────────────────────────────────────────────────
# Public hostname carriers use to reach this server (no scheme),
# e.g. outreach-voice-agent.onrender.com
PUBLIC_HOST=
PORT=8000

# Protects /api/v1 (X-API-Key header). Generate: openssl rand -hex 24
# Leave empty ONLY for local development.
OUTREACH_API_KEY=

# ── Persistence ──────────────────────────────────────────────
# SQLite file by default; use postgres://... in production.
DATABASE_URL=sqlite:///outreach.db

# ── Webhooks (optional) ──────────────────────────────────────
# Comma-separated URLs receiving call.started / call.ended /
# call.analyzed / campaign.completed events (HMAC-signed).
WEBHOOK_URLS=
WEBHOOK_SECRET=

# ── Behaviour ────────────────────────────────────────────────
# Agent answering calls to unknown/unmapped numbers.
DEFAULT_AGENT_ID=seaside-hotel
MAX_CALL_SECONDS=600
IDLE_TIMEOUT_SECONDS=30
